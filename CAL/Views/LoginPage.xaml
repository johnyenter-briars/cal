<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CAL.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False">

    <Grid Padding="24" RowDefinitions="*,Auto,*">
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="20">
            <VerticalStackLayout Spacing="16">
                <VerticalStackLayout Spacing="4">
                    <Label Text="CAL" Style="{StaticResource TitleLabelStyle}" HorizontalTextAlignment="Center" />
                    <Label Text="Calendar access is ready on this device." TextColor="{StaticResource MutedTextColor}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <Button Text="Login" Command="{Binding LoginCommand}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
