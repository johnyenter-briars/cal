<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CAL.Views.CalendarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Models="clr-namespace:CAL.Models"
    xmlns:ViewModels="clr-namespace:CAL.ViewModels"
    xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:xc="clr-namespace:XCalendar.Maui.Views;assembly=XCalendar.Maui"
    xmlns:xcConverters="clr-namespace:XCalendar.Maui.Converters;assembly=XCalendar.Maui"
    x:Name="This"
    x:DataType="ViewModels:CalendarViewModel"
    Title="Calendar">

    <ContentPage.Resources>
        <xcConverters:StringCharLimitConverter x:Key="StringCharLimitConverter" />
        <mct:VariableMultiValueConverter x:Key="AllTrueConverter" ConditionType="All" />
        <mct:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Series" Command="{Binding AddSeriesCommand}" />
        <ToolbarItem Text="Event" Command="{Binding AddEventCommand}" />
        <ToolbarItem IconImageSource="icons8_restart_50.png" Command="{Binding RefreshEventsCommand}" />
    </ContentPage.ToolbarItems>

    <Grid Padding="16" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="CalendarRow" Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Border
                BackgroundColor="{StaticResource SurfaceColor}"
                HorizontalOptions="Fill"
                Padding="8,4"
                Stroke="{StaticResource MutedBorderColor}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,38,38" ColumnSpacing="8" HeightRequest="38">
                    <Border
                        BackgroundColor="{StaticResource InputBackgroundColor}"
                        Padding="10,0"
                        Stroke="{StaticResource MutedBorderColor}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Label
                            FontAttributes="Bold"
                            FontSize="15"
                            Text="{Binding SelectedMonthYear}"
                            TextColor="{StaticResource PrimaryTextColor}"
                            VerticalTextAlignment="Center" />
                    </Border>

                    <ImageButton
                        Grid.Column="1"
                        BackgroundColor="{StaticResource SurfaceAltColor}"
                        BorderColor="{StaticResource MutedBorderColor}"
                        BorderWidth="1"
                        Command="{Binding OpenMonthPickerCommand}"
                        CornerRadius="10"
                        HeightRequest="38"
                        Padding="7"
                        Source="icons8_calendar_50.png"
                        WidthRequest="38" />

                    <ImageButton
                        x:Name="CalendarToggleButton"
                        Grid.Column="2"
                        BackgroundColor="{StaticResource SurfaceAltColor}"
                        BorderColor="{StaticResource MutedBorderColor}"
                        BorderWidth="1"
                        Clicked="CalendarToggleButton_Clicked"
                        CornerRadius="10"
                        HeightRequest="38"
                        Padding="7"
                        Source="chevron_up.png"
                        WidthRequest="38" />
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="CalendarPanel" Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="2,2,2,2">
            <Grid>
                <xc:CalendarView
                    x:Name="MainCalendarView"
                    BackwardsArrowCommand="{Binding NavigateCalendarCommand}"
                    BackwardsArrowCommandParameter="{Binding EventCalendar.BackwardsNavigationAmount}"
                    DayNamesHeightRequest="0"
                    Days="{Binding EventCalendar.Days}"
                    DaysOfWeek="{Binding EventCalendar.DayNamesOrder}"
                    ForwardsArrowCommand="{Binding NavigateCalendarCommand}"
                    ForwardsArrowCommandParameter="{Binding EventCalendar.ForwardsNavigationAmount}"
                    HeightRequest="350"
                    NavigatedDate="{Binding EventCalendar.NavigatedDate}"
                    Style="{StaticResource DefaultCalendarViewStyle}">

                <xc:CalendarView.NavigationViewTemplate>
                    <ControlTemplate>
                        <Grid RowDefinitions="42,18" RowSpacing="0" Margin="0,-4,0,0">
                            <Grid ColumnDefinitions="*,44,112,44,*" HeightRequest="42">
                                <ImageButton
                                    Grid.Column="1"
                                    BackgroundColor="Transparent"
                                    Command="{Binding BackwardsArrowCommand, Source={RelativeSource TemplatedParent}}"
                                    CommandParameter="{Binding BackwardsArrowCommandParameter, Source={RelativeSource TemplatedParent}}"
                                    HeightRequest="36"
                                    Padding="6"
                                    Source="chevron_left.png"
                                    VerticalOptions="Center"
                                    WidthRequest="36" />

                                <Label
                                    Grid.Column="2"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    MaxLines="2"
                                    Text="{Binding Text, Source={RelativeSource TemplatedParent}}"
                                    TextColor="{StaticResource PrimaryTextColor}"
                                    VerticalTextAlignment="Center" />

                                <ImageButton
                                    Grid.Column="3"
                                    BackgroundColor="Transparent"
                                    Command="{Binding ForwardsArrowCommand, Source={RelativeSource TemplatedParent}}"
                                    CommandParameter="{Binding ForwardsArrowCommandParameter, Source={RelativeSource TemplatedParent}}"
                                    HeightRequest="36"
                                    Padding="6"
                                    Source="chevron_right.png"
                                    VerticalOptions="Center"
                                    WidthRequest="36" />
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*,*" Padding="4,0">
                                <Label Text="Sun" TextColor="{StaticResource MutedTextColor}" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text="Mon" TextColor="{StaticResource MutedTextColor}" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="Tue" TextColor="{StaticResource MutedTextColor}" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                <Label Grid.Column="3" Text="Wed" TextColor="{StaticResource MutedTextColor}" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                <Label Grid.Column="4" Text="Thu" TextColor="{StaticResource MutedTextColor}" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                <Label Grid.Column="5" Text="Fri" TextColor="{StaticResource MutedTextColor}" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                                <Label Grid.Column="6" Text="Sat" TextColor="{StaticResource MutedTextColor}" FontAttributes="Bold" FontSize="12" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </xc:CalendarView.NavigationViewTemplate>

                <xc:CalendarView.DayTemplate>
                    <DataTemplate x:DataType="Models:EventDay">
                        <Border
                            Margin="1"
                            BackgroundColor="Transparent"
                            HeightRequest="46"
                            WidthRequest="46">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>

                            <xc:DayView
                                CurrentMonthCommand="{Binding BindingContext.ChangeDateSelectionCommand, Source={x:Reference This}}"
                                CurrentMonthCommandParameter="{Binding DateTime}"
                                DateTime="{Binding DateTime}"
                                IsCurrentMonth="{Binding IsCurrentMonth}"
                                IsInvalid="{Binding IsInvalid}"
                                IsSelected="{Binding IsSelected}"
                                IsToday="{Binding IsToday}"
                                SelectedBackgroundColor="{StaticResource DaySelectedBackgroundColor}"
                                SelectedCommand="{Binding BindingContext.ChangeDateSelectionCommand, Source={x:Reference This}}"
                                SelectedCommandParameter="{Binding DateTime}"
                                Style="{StaticResource DefaultDayViewStyle}"
                                TodayCommand="{Binding BindingContext.ChangeDateSelectionCommand, Source={x:Reference This}}"
                                TodayCommandParameter="{Binding DateTime}">

                                <xc:DayView.ControlTemplate>
                                    <ControlTemplate>
                                        <Grid BindingContext="{Binding BindingContext, Source={RelativeSource TemplatedParent}}" RowSpacing="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="29" />
                                                <RowDefinition Height="17" />
                                            </Grid.RowDefinitions>

                                            <ContentPresenter
                                                Grid.Row="0"
                                                Margin="0,2,0,0"
                                                VerticalOptions="Start" />

                                            <HorizontalStackLayout
                                                Grid.Row="1"
                                                BindableLayout.ItemsSource="{Binding Events}"
                                                HorizontalOptions="Center"
                                                Spacing="2">
                                                <HorizontalStackLayout.IsVisible>
                                                    <MultiBinding Converter="{StaticResource AllTrueConverter}">
                                                        <Binding Path="IsCurrentMonth" />
                                                        <Binding Converter="{StaticResource InvertedBoolConverter}" Path="IsInvalid" />
                                                    </MultiBinding>
                                                </HorizontalStackLayout.IsVisible>

                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="Models:CalendarEvent">
                                                        <BoxView
                                                            Color="{Binding Color}"
                                                            CornerRadius="3"
                                                            HeightRequest="6"
                                                            WidthRequest="6" />
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </ControlTemplate>
                                </xc:DayView.ControlTemplate>
                            </xc:DayView>
                        </Border>
                    </DataTemplate>
                </xc:CalendarView.DayTemplate>
                </xc:CalendarView>
            </Grid>
        </Border>

        <CollectionView
            x:Name="EventsList"
            Grid.Row="2"
            ItemsSource="{Binding SelectedEvents}"
            SelectedItem="{Binding SelectedEvent}"
            SelectionMode="Single">

            <CollectionView.EmptyView>
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,4,0,0">
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="No Events" Style="{StaticResource TitleLabelStyle}" HorizontalTextAlignment="Center" />
                        <Label Text="This date has nothing scheduled." TextColor="{StaticResource MutedTextColor}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </CollectionView.EmptyView>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemSizingStrategy>
                <OnPlatform x:TypeArguments="ItemSizingStrategy">
                    <On Platform="iOS">MeasureFirstItem</On>
                    <On Platform="Android">MeasureAllItems</On>
                </OnPlatform>
            </CollectionView.ItemSizingStrategy>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="Models:CalendarEvent">
                    <Border Style="{StaticResource CardBorderStyle}" Padding="0" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="6,96,*" MinimumHeightRequest="92">
                            <BoxView Grid.Column="0" Color="{Binding Color}" />

                            <VerticalStackLayout Grid.Column="1" Padding="14,12" Spacing="2">
                                <Label Text="{Binding StartTime, StringFormat='{0:HH:mm}'}" FontAttributes="Bold" FontSize="20" TextColor="{StaticResource PrimaryTextColor}" />
                                <Label Text="{Binding EndTime, StringFormat='{0:HH:mm}'}" FontSize="13" TextColor="{StaticResource MutedTextColor}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" Padding="4,12,14,12" Spacing="4">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource PrimaryTextColor}" />
                                <Label Text="{Binding Description}" FontSize="13" TextColor="{StaticResource MutedTextColor}" LineBreakMode="TailTruncation" MaxLines="2" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid
            Grid.RowSpan="3"
            BackgroundColor="#99000000"
            IsVisible="{Binding IsMonthPickerOpen}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseMonthPickerCommand}" />
            </Grid.GestureRecognizers>

            <Border
                BackgroundColor="{StaticResource SurfaceColor}"
                HorizontalOptions="Center"
                Padding="16"
                VerticalOptions="Center"
                WidthRequest="280">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Jump to Month" Style="{StaticResource TitleLabelStyle}" FontSize="18" />

                    <Grid ColumnDefinitions="*,96" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Month" Style="{StaticResource SectionLabelStyle}" Margin="0" />
                            <Picker
                                ItemsSource="{Binding MonthOptions}"
                                SelectedIndex="{Binding PendingMonthIndex, Mode=TwoWay}"
                                Title="Month" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Year" Style="{StaticResource SectionLabelStyle}" Margin="0" />
                            <Picker
                                ItemsSource="{Binding YearOptions}"
                                SelectedItem="{Binding PendingYear, Mode=TwoWay}"
                                Title="Year" />
                        </VerticalStackLayout>
                    </Grid>

                    <Button Command="{Binding SubmitMonthPickerCommand}" Text="Submit" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
