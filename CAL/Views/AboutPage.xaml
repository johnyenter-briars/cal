<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CAL.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:CAL.ViewModels"
    Title="About">

    <ContentPage.BindingContext>
        <vm:SettingsViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Label Text="About CAL" Style="{StaticResource TitleLabelStyle}" />

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Build Version" Style="{StaticResource SectionLabelStyle}" Margin="0" />
                        <Label Text="Installed application build" TextColor="{StaticResource MutedTextColor}" FontSize="13" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="{Binding BuildVersion}" TextColor="{StaticResource PrimaryColor}" FontAttributes="Bold" VerticalOptions="Center" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
