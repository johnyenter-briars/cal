<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="CAL.Views.EditSeriesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:CAL.ViewModels"
    Shell.PresentationMode="ModalAnimated"
    Title="Series">

    <ContentPage.BindingContext>
        <vm:EditSeriesViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="14">
                <Label Text="Series Details" Style="{StaticResource TitleLabelStyle}" />

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Name" Style="{StaticResource SectionLabelStyle}" />
                        <Entry Text="{Binding Name, Mode=TwoWay}" Placeholder="Series name" />

                        <Label Text="Description" Style="{StaticResource SectionLabelStyle}" />
                        <Editor Text="{Binding Description, Mode=TwoWay}" Placeholder="Notes, agenda, location" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="10" RowSpacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Series Start" Style="{StaticResource SectionLabelStyle}" />
                            <DatePicker Date="{Binding SeriesStartsOnSelectedDate}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Series End" Style="{StaticResource SectionLabelStyle}" />
                            <DatePicker Date="{Binding SeriesEndsOnSelectedDate}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Spacing="6">
                            <Label Text="Event Start" Style="{StaticResource SectionLabelStyle}" />
                            <TimePicker Time="{Binding SubEventsStartTime, Mode=TwoWay}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                            <Label Text="Event End" Style="{StaticResource SectionLabelStyle}" />
                            <TimePicker Time="{Binding SubEventEndTime}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Repeats" Style="{StaticResource SectionLabelStyle}" />

                        <Grid ColumnDefinitions="*,Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <Label Text="Monday" VerticalOptions="Center" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding RepeatOnMon}" />
                            <Label Grid.Column="2" Text="Tuesday" VerticalOptions="Center" />
                            <CheckBox Grid.Column="3" IsChecked="{Binding RepeatOnTues}" />

                            <Label Grid.Row="1" Text="Wednesday" VerticalOptions="Center" />
                            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding RepeatOnWed}" />
                            <Label Grid.Row="1" Grid.Column="2" Text="Thursday" VerticalOptions="Center" />
                            <CheckBox Grid.Row="1" Grid.Column="3" IsChecked="{Binding RepeatOnThurs}" />

                            <Label Grid.Row="2" Text="Friday" VerticalOptions="Center" />
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding RepeatOnFri}" />
                            <Label Grid.Row="2" Grid.Column="2" Text="Saturday" VerticalOptions="Center" />
                            <CheckBox Grid.Row="2" Grid.Column="3" IsChecked="{Binding RepeatOnSat}" />

                            <Label Grid.Row="3" Text="Sunday" VerticalOptions="Center" />
                            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding RepeatOnSun}" />
                            <Label Grid.Row="3" Grid.Column="2" Text="Yearly Event" VerticalOptions="Center" />
                            <CheckBox Grid.Row="3" Grid.Column="3" IsChecked="{Binding YearlyEvent}" />
                        </Grid>

                        <Label Text="Repeat Every # Weeks" Style="{StaticResource SectionLabelStyle}" />
                        <Entry Keyboard="Numeric" Text="{Binding RepeatEveryWeek, Mode=TwoWay}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Appearance" Style="{StaticResource SectionLabelStyle}" />
                        <Border BackgroundColor="{StaticResource InputBackgroundColor}" Stroke="{StaticResource MutedBorderColor}" StrokeThickness="1" Padding="10,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="28,*" ColumnSpacing="10">
                                <Border
                                    BackgroundColor="{Binding CurrentlySelectedColor}"
                                    HeightRequest="18"
                                    VerticalOptions="Center"
                                    WidthRequest="18">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="9" />
                                    </Border.StrokeShape>
                                </Border>
                                <Picker
                                    x:Name="picker"
                                    Grid.Column="1"
                                    BackgroundColor="Transparent"
                                    SelectedIndexChanged="picker_SelectedIndexChanged"
                                    Title="Select a Color">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>Red</x:String>
                                            <x:String>Blue</x:String>
                                            <x:String>Green</x:String>
                                            <x:String>Orange</x:String>
                                            <x:String>Yellow</x:String>
                                            <x:String>Purple</x:String>
                                            <x:String>Pink</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                            <Label Text="Notify for generated events" VerticalOptions="Center" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding ShouldNotify}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1" Padding="16,10" ColumnDefinitions="52,*,*" ColumnSpacing="10" BackgroundColor="{StaticResource SurfaceColor}">
            <ImageButton BackgroundColor="{StaticResource DangerColor}" Command="{Binding DeleteCommand}" Source="icons8_trash_24" />
            <Button Grid.Column="1" BackgroundColor="{StaticResource SurfaceAltColor}" TextColor="{StaticResource PrimaryTextColor}" Command="{Binding CancelCommand}" Text="Cancel" />
            <Button Grid.Column="2" Command="{Binding SaveCommand}" Text="Save" />
        </Grid>
    </Grid>
</ContentPage>
