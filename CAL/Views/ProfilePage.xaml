<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CAL.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:CAL.ViewModels"
    Title="Profile">

    <ContentPage.BindingContext>
        <vm:ProfileViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Label Text="Profile" Style="{StaticResource TitleLabelStyle}" />

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="First Name" Style="{StaticResource SectionLabelStyle}" />
                    <Entry Text="{Binding CalUser.FirstName}" />
                    <Label Text="Last Name" Style="{StaticResource SectionLabelStyle}" />
                    <Entry Text="{Binding CalUser.LastName}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Account" Style="{StaticResource SectionLabelStyle}" />
                    <Entry Text="{Binding CalUser.Id}" />
                    <Entry Text="{Binding CalUser.EntityType}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
