<?xml version="1.0" encoding="UTF-8" ?>
<ContentView
    x:Class="CAL.Controls.CalendarEvent"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Models="clr-namespace:CAL.Client.Models.Cal;assembly=CAL.Client"
    xmlns:converters="clr-namespace:CAL.Converters"
    x:Name="eventTemplate"
    x:DataType="{x:Type Models:Event}">

    <ContentView.Resources>
        <ResourceDictionary>
            <converters:StringToColorConverter x:Key="ColorConverter" />
        </ResourceDictionary>
    </ContentView.Resources>

    <Border Style="{StaticResource CardBorderStyle}" Padding="0" Margin="0,5">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped" />
        </Border.GestureRecognizers>

        <Grid ColumnDefinitions="6,*,48" MinimumHeightRequest="92">
            <BoxView Grid.Column="0" Color="{Binding Color, Converter={StaticResource ColorConverter}}" />

            <VerticalStackLayout Grid.Column="1" Padding="14,12" Spacing="4">
                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource PrimaryTextColor}" />
                <Label Text="{Binding StartTime, StringFormat='{0:MM/dd HH\\:mm}'}" FontSize="13" TextColor="{StaticResource PrimaryColor}" />
                <Label Text="{Binding Description}" FontSize="13" TextColor="{StaticResource MutedTextColor}" MaxLines="2" />
            </VerticalStackLayout>

            <Grid Grid.Column="2" Padding="8" VerticalOptions="Center">
                <Border BackgroundColor="{StaticResource SurfaceAltColor}" HeightRequest="34" IsVisible="{Binding IsPartOfSeries}" WidthRequest="34">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Image Source="icons8_bursts_50.png">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped" />
                        </Image.GestureRecognizers>
                    </Image>
                </Border>
                <Border BackgroundColor="{StaticResource SurfaceAltColor}" HeightRequest="34" IsVisible="{Binding IsSingularEvent}" WidthRequest="34">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Image Source="icons8_one_finger_50.png">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped" />
                        </Image.GestureRecognizers>
                    </Image>
                </Border>
            </Grid>
        </Grid>
    </Border>
</ContentView>
