<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:xc="clr-namespace:XCalendar.Maui.Views;assembly=XCalendar.Maui"
             x:Class="CAL.App">
    <Application.Resources>
        <Color x:Key="PageBackgroundColor">#0B0B0D</Color>
        <Color x:Key="SurfaceColor">#151518</Color>
        <Color x:Key="SurfaceAltColor">#202024</Color>
        <Color x:Key="ElevatedSurfaceColor">#2A2A30</Color>
        <Color x:Key="InputBackgroundColor">#1B1B1F</Color>
        <Color x:Key="BorderColor">#3A3A42</Color>
        <Color x:Key="MutedBorderColor">#2A2A31</Color>

        <Color x:Key="PrimaryColor">#8B5CF6</Color>
        <Color x:Key="PrimaryPressedColor">#6D28D9</Color>
        <Color x:Key="SecondaryColor">#A78BFA</Color>
        <Color x:Key="DangerColor">#E11D48</Color>
        <Color x:Key="InfoColor">#A78BFA</Color>

        <Color x:Key="PrimaryTextColor">#F7F7F8</Color>
        <Color x:Key="ContentTextColor">#E6E6E8</Color>
        <Color x:Key="MutedTextColor">#A1A1AA</Color>
        <Color x:Key="InverseTextColor">#111113</Color>
        <Color x:Key="PlaceholderTextColor">#73737C</Color>

        <Color x:Key="ContentBackgroundColor">#151518</Color>
        <Color x:Key="CalendarPrimaryColor">#8B5CF6</Color>
        <Color x:Key="CalendarBackgroundColor">#151518</Color>
        <Color x:Key="CalendarTertiaryColor">#52525B</Color>
        <Color x:Key="CalendarPrimaryTextColor">#F7F7F8</Color>
        <Color x:Key="CalendarBackgroundTextColor">#E6E6E8</Color>
        <Color x:Key="DaySelectedBackgroundColor">#6D28D9</Color>

        <x:Double x:Key="SmallFontSize">13</x:Double>
        <x:Double x:Key="MediumFontSize">15</x:Double>
        <x:Double x:Key="LargeFontSize">20</x:Double>

        <Style TargetType="{x:Type ContentPage}">
            <Setter Property="BackgroundColor" Value="{StaticResource PageBackgroundColor}" />
            <Setter Property="Shell.BackgroundColor" Value="{StaticResource SurfaceColor}" />
            <Setter Property="Shell.ForegroundColor" Value="{StaticResource PrimaryTextColor}" />
            <Setter Property="Shell.TitleColor" Value="{StaticResource PrimaryTextColor}" />
            <Setter Property="Shell.UnselectedColor" Value="{StaticResource MutedTextColor}" />
            <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource SurfaceColor}" />
            <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource PrimaryColor}" />
            <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource PrimaryColor}" />
            <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource MutedTextColor}" />
        </Style>

        <Style TargetType="{x:Type Label}">
            <Setter Property="TextColor" Value="{StaticResource ContentTextColor}" />
            <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
            <Setter Property="LineBreakMode" Value="TailTruncation" />
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="{x:Type Label}">
            <Setter Property="TextColor" Value="{StaticResource MutedTextColor}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="Margin" Value="2,8,0,0" />
        </Style>

        <Style x:Key="TitleLabelStyle" TargetType="{x:Type Label}">
            <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>

        <Style TargetType="{x:Type Entry}">
            <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            <Setter Property="PlaceholderColor" Value="{StaticResource PlaceholderTextColor}" />
            <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
            <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
            <Setter Property="HeightRequest" Value="46" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style TargetType="{x:Type Editor}">
            <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            <Setter Property="PlaceholderColor" Value="{StaticResource PlaceholderTextColor}" />
            <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
            <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
            <Setter Property="AutoSize" Value="TextChanges" />
            <Setter Property="MinimumHeightRequest" Value="110" />
        </Style>

        <Style TargetType="{x:Type Picker}">
            <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            <Setter Property="TitleColor" Value="{StaticResource PlaceholderTextColor}" />
            <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
            <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
            <Setter Property="HeightRequest" Value="46" />
        </Style>

        <Style TargetType="{x:Type DatePicker}">
            <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
            <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
            <Setter Property="HeightRequest" Value="46" />
        </Style>

        <Style TargetType="{x:Type TimePicker}">
            <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
            <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
            <Setter Property="HeightRequest" Value="46" />
        </Style>

        <Style TargetType="{x:Type SearchBar}">
            <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            <Setter Property="PlaceholderColor" Value="{StaticResource PlaceholderTextColor}" />
            <Setter Property="BackgroundColor" Value="{StaticResource InputBackgroundColor}" />
            <Setter Property="CancelButtonColor" Value="{StaticResource PrimaryColor}" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
            <Setter Property="TextColor" Value="{StaticResource InverseTextColor}" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HeightRequest" Value="46" />
            <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style TargetType="{x:Type ImageButton}">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HeightRequest" Value="46" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Color" Value="{StaticResource PrimaryColor}" />
        </Style>

        <Style TargetType="{x:Type Grid}">
            <Setter Property="ColumnSpacing" Value="0" />
            <Setter Property="RowSpacing" Value="0" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
            <Setter Property="Stroke" Value="{StaticResource MutedBorderColor}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="8" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DefaultCalendarViewStyle" TargetType="{x:Type xc:CalendarView}">
            <Setter Property="BackgroundColor" Value="{StaticResource CalendarBackgroundColor}" />
        </Style>

        <Style x:Key="DefaultNavigationViewStyle" TargetType="{x:Type xc:NavigationView}">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="ArrowColor" Value="{StaticResource PrimaryColor}" />
            <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            <Setter Property="HeightRequest" Value="48" />
        </Style>

        <Style x:Key="DefaultDayViewStyle" TargetType="{x:Type xc:DayView}">
            <Setter Property="CurrentMonthTextColor" Value="{StaticResource CalendarBackgroundTextColor}" />
            <Setter Property="TodayTextColor" Value="{StaticResource SecondaryColor}" />
            <Setter Property="InvalidTextColor" Value="{StaticResource CalendarTertiaryColor}" />
            <Setter Property="SelectedBackgroundColor" Value="{StaticResource DaySelectedBackgroundColor}" />
            <Setter Property="SelectedTextColor" Value="{StaticResource PrimaryTextColor}" />
        </Style>
    </Application.Resources>
</Application>
